# ─────────────────────────────────────────────────────────────────────────────
# MarketNoise — Production Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=your-ec2-ip,your-domain.com

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://marketnoise:password@your-rds-endpoint.amazonaws.com:5432/marketnoise

# ── Redis (Upstash — note double-s for TLS) ───────────────────────────────────
REDIS_URL=rediss://default:YOUR_TOKEN@boss-arachnid-102801.upstash.io:6379

# ── CORS (comma-separated, no trailing slash) ─────────────────────────────────
# In production nginx serves everything on one domain — CORS is only needed if
# you ever split frontend/backend to different domains.
CORS_ALLOWED_ORIGINS=http://your-ec2-ip,https://your-domain.com

# ── External API Keys ─────────────────────────────────────────────────────────
GNEWS_API_KEY=your-gnews-key
TWELVEDATA_API_KEY=your-twelvedata-key

# ── Reddit API (register at https://www.reddit.com/prefs/apps) ───────────────
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=MarketNoise/1.0

# ── Per-user API key encryption ───────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key
